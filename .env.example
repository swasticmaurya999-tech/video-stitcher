# ── Copy to .env and fill in. All values have sensible defaults except cloud keys. ──

# --- Storage backend: "local" (default, no keys) or "r2" ---
STORAGE_BACKEND=local
# R2 (only needed when STORAGE_BACKEND=r2)
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=video-stitcher
PRESIGN_TTL=3600

# --- LLM planners (failover chain). Empty keys are skipped → heuristic fallback. ---
PLANNER_CHAIN=groq,heuristic    # groq (with its keys) → heuristic. Add 'gemini' if you have a working key.
GEMINI_API_KEY=
GROQ_API_KEY=                    # ONE key, or comma-separated for multi-account failover: key1,key2
LLM_TIMEOUT=30
ENABLE_CRITIC=true       # 2nd LLM pass reviews the storyboard and refines if flagged
CRITIC_MAX_ITERS=2

# --- Limits ---
MAX_FILES=50
MIN_FILES=1
MAX_FILE_SIZE_MB=100
MAX_TOTAL_SIZE_MB=1024
MIN_OUTPUT_SEC=10
MAX_OUTPUT_SEC=120
CLIP_SECONDS=3
MIN_CLIP=1.0

# --- Output profile ---
TARGET_WIDTH=1920
TARGET_HEIGHT=1080
FPS=30
ASPECT=16:9            # 16:9 | 9:16 | 1:1

# --- Feature toggles (trade quality <-> compute; each is wired) ---
ENABLE_CLIP=false        # CLIP visual tags (requires requirements-ml.txt)
ENABLE_DETECT=false      # YOLO object/person detection (requires requirements-ml.txt)
ENABLE_WHISPER=true      # speech transcription + speech-aware cuts
ENABLE_STABILIZE=false   # ffmpeg deshake on shaky clips
ENABLE_CAPTIONS=true     # burn word-synced captions of the speech (readable on mute)
ENABLE_TRANSITIONS=true  # crossfade dissolves between clips (vs hard cuts)
CROSSFADE_DURATION=0.4   # seconds of dissolve
ENABLE_BEATSYNC=false    # nudge cuts onto music beats (needs librosa via requirements-ml.txt)
ENABLE_ENDFADE=true      # fade in at start + fade to black at end (clean ending)
AUDIO_MODE=voiceover     # voiceover = keep clip speech + duck music under it (recommended) |
                         # music = mute clips, music only | mix = music under clip audio | clips = clip audio only
MUSIC_PATH=              # force one track; empty = mood-picked from app/assets/music/<mood>/
MUSIC_LIBRARY_DIR=app/assets/music
MUSIC_VOLUME=0.35        # 0..1 base music level (mix mode)

# --- Analysis bounding ---
WHISPER_MODEL=base
WHISPER_TASK=translate     # translate any language to English (robust understanding) | transcribe
DEDUP_THRESHOLD=0.82       # transcript similarity above which clips count as near-duplicates
ANALYZE_FPS=1.0
ANALYZE_MAXDIM=480
MAX_SEGMENTS_CONSIDERED=120

# --- Worker / lifecycle ---
WORKER_CONCURRENCY=1
MAX_JOB_ATTEMPTS=2
UPLOAD_TTL_H=24
OUTPUT_TTL_H=24
SEGMENT_TTL_H=24
DISK_MIN_FREE_MB=500
JANITOR_INTERVAL_SEC=3600

# --- Paths ---
DATA_DIR=./data
DB_PATH=./data/app.db
TEMP_DIR=./data/tmp
